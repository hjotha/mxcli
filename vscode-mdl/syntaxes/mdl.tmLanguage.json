{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MDL",
  "scopeName": "source.mdl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#variables" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#control-keywords" },
    { "include": "#widget-keywords" },
    { "include": "#ddl-keywords" },
    { "include": "#object-keywords" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.mdl",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.mdl",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-dash.mdl",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.mdl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mdl",
              "match": "''|\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.mdl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mdl",
              "match": "\"\"|\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.other.dollar.mdl",
          "begin": "\\$\\$",
          "end": "\\$\\$"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.mdl",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mdl",
          "match": "-?\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mdl",
          "match": "(?i)\\b(String|Integer|Long|Decimal|Boolean|DateTime|Date|AutoNumber|Binary|HashedString|Currency|Float|StringTemplate|Enum|List)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.mdl",
          "match": "(?i)\\b(true|false|null|empty)\\b"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.mdl",
          "match": "(?i)\\b(CREATE|ALTER|DROP|RENAME|MOVE|MODIFY|BEGIN|END|IF|THEN|ELSE|ELSIF|ELSEIF|LOOP|WHILE|RETURN|RETURNS|RETURNING|BREAK|CONTINUE|THROW|DECLARE|SET|CHANGE|RETRIEVE|DELETE|COMMIT|ROLLBACK|CALL|LOG|SHOW|CLOSE|SELECT|FROM|WHERE|HAVING|ORDER\\s+BY|GROUP\\s+BY|SORT\\s+BY|LIMIT|OFFSET|AS|IN|ON|JOIN|LEFT|RIGHT|INNER|OUTER|FULL|CROSS|ASC|DESC|DISTINCT|ALL|WITH|WITHOUT|CASE|WHEN|AND|OR|NOT|BETWEEN|LIKE|EXISTS|UNION|INTERSECT|SUBTRACT|CONTAINS|IS\\s+NOT\\s+NULL|IS\\s+NULL|NOT\\s+NULL|VALIDATION|FEEDBACK|IMPORT|EXPORT|UPDATE|REFRESH|CHECK|EXECUTE|RAISE)\\b"
        }
      ]
    },
    "widget-keywords": {
      "patterns": [
        {
          "name": "entity.name.tag.mdl",
          "match": "(?i)\\b(LAYOUTGRID|DATAGRID|DATAVIEW|LISTVIEW|GALLERY|CONTAINER|ROW|COLUMN|ITEM|CONTROLBAR|SEARCHBAR|NAVIGATIONLIST|ACTIONBUTTON|LINKBUTTON|BUTTON|DYNAMICTEXT|STATICTEXT|TEXTBOX|TEXTAREA|DATEPICKER|RADIOBUTTONS|DROPDOWN|COMBOBOX|CHECKBOX|REFERENCESELECTOR|INPUTREFERENCESETSELECTOR|FILEINPUT|IMAGEINPUT|CUSTOMWIDGET|TEXTFILTER|NUMBERFILTER|DROPDOWNFILTER|DATEFILTER|SNIPPETCALL|PLACEHOLDER|HEADER|FOOTER|CONTENT)\\b"
        }
      ]
    },
    "ddl-keywords": {
      "patterns": [
        {
          "name": "keyword.other.mdl",
          "match": "(?i)\\b(MICROFLOW|NANOFLOW|ENTITY|ASSOCIATION|ENUMERATION|PAGE|SNIPPET|LAYOUT|NOTEBOOK|CONSTANT|MODULE|ATTRIBUTE|INDEX|GENERALIZATION|EXTENDS|PERSISTENT|NON-PERSISTENT|REFERENCE|REFERENCE_?SET|WIDGET|DATASOURCE|SELECTION|DATABASE|FOLDER|WORKFLOW|STRUCTURE|MAPPING|JSON|CONFIGURATION|CONTRACT|NAVIGATION|SETTINGS)\\b"
        }
      ]
    },
    "object-keywords": {
      "patterns": [
        {
          "name": "keyword.other.mdl",
          "match": "(?i)\\b(BINDS|PARAMS|CAPTION|LABEL|TITLE|STYLE|BUTTONSTYLE|CLASS|ACTION|EDITABLE|READONLY|VISIBLE|SAVE_CHANGES|CANCEL_CHANGES|CLOSE_PAGE|SHOW_PAGE|DELETE_ACTION|DELETE_OBJECT|CREATE_OBJECT|CALL_MICROFLOW|CALL_NANOFLOW|OPEN_LINK|SIGN_OUT|PRIMARY|SUCCESS|DANGER|WARNING|INFO|TEMPLATE|ONCLICK|ONCHANGE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mdl",
          "match": "<>|!=|<=|>=|=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.mdl",
          "match": "\\+|-|\\*|/|%"
        }
      ]
    }
  }
}
