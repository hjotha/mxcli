/**
 * Test Suite: All tests for MathTest.Fibonacci
 *
 * This microflow runs all unit tests for Fibonacci and returns
 * a summary of results.
 */
CREATE MICROFLOW MathTest.TestSuite_Fibonacci ()
RETURNS String AS $Summary
FOLDER 'Tests/Math'
COMMENT'TestSuite_Fibonacci'
BEGIN
  DECLARE $TestsPassed Integer = 0;
  DECLARE $TotalTests Integer = 5;
  DECLARE $Summary String = '';

  -- Run all Fibonacci tests
  $Result1 = CALL MICROFLOW MathTest.UT_Fibonacci_0_Returns0();
  IF $Result1 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result2 = CALL MICROFLOW MathTest.UT_Fibonacci_1_Returns1();
  IF $Result2 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result3 = CALL MICROFLOW MathTest.UT_Fibonacci_10_Returns55();
  IF $Result3 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result4 = CALL MICROFLOW MathTest.UT_Fibonacci_20_Returns6765();
  IF $Result4 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  $Result5 = CALL MICROFLOW MathTest.UT_Fibonacci_Negative_Returns0();
  IF $Result5 != empty THEN
    SET $TestsPassed = $TestsPassed + 1;
  END IF;

  SET $Summary = 'Test Suite: Fibonacci - Passed: ' + toString($TestsPassed) + ' / Total: ' + toString($TotalTests);
  LOG INFO NODE 'TestSuite' '{1}' WITH ({1} = $Summary);

  RETURN $Summary;
END;
/

-- ============================================================================
-- Master Test Suite
-- ============================================================================

/**
 * Master Test Suite: All Math tests
 *
 * Runs all test suites and returns overall summary.
 */
CREATE MICROFLOW MathTest.TestSuite_All ()
RETURNS String AS $Summary
FOLDER 'Tests/Math'
COMMENT'TestSuite_All'
BEGIN
  DECLARE $Summary String = '';

  -- Run all test suites
  $IsPrimeResult = CALL MICROFLOW MathTest.TestSuite_IsPrime();
  LOG INFO NODE 'TestSuite' '{1}' WITH ({1} = $IsPrimeResult);

  $FibonacciResult = CALL MICROFLOW MathTest.TestSuite_Fibonacci();
  LOG INFO NODE 'TestSuite' '{1}' WITH ({1} = $FibonacciResult);

  SET $Summary = 'All Math Tests Complete. ' + $IsPrimeResult + ' | ' + $FibonacciResult;

  RETURN $Summary;
END;
/

-- ============================================================================
-- Test Runner Page
-- ============================================================================

/**
 * Math Test Runner Page
 *
 * A dashboard to run all Math test microflows and view results.
 */
CREATE PAGE MathTest.MathTestRunner
(
  Title: 'Math Test Runner',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'mathtestrunner',
  Folder: 'Tests/Math'
)
{
  LAYOUTGRID gridMain {
    ROW rowTitle {
      COLUMN colTitle (DesktopWidth: 12) {
        DYNAMICTEXT titleHeader (Content: 'Math Microflow Test Runner', RenderMode: H2)
        DYNAMICTEXT textDescription (Content: 'Run unit tests for MathTest.IsPrime and MathTest.Fibonacci microflows', RenderMode: Paragraph)
      }
    }
    ROW rowAll {
      COLUMN colAll (DesktopWidth: 12) {
        DYNAMICTEXT sectionAll (Content: 'Run All Tests', RenderMode: H4)
      }
    }
    ROW rowAllBtn {
      COLUMN colAllBtn (DesktopWidth: 4) {
        ACTIONBUTTON btnRunAll (Caption: 'Run All Math Tests', Action: MICROFLOW MathTest.TestSuite_All, ButtonStyle: Primary)
      }
    }
    ROW rowPrimeHeader {
      COLUMN colPrimeHeader (DesktopWidth: 12) {
        DYNAMICTEXT sectionIsPrime (Content: 'IsPrime Tests', RenderMode: H4)
      }
    }
    ROW rowPrimeTests {
      COLUMN colPrimeSuite (DesktopWidth: 3) {
        ACTIONBUTTON btnIsPrimeSuite (Caption: 'Run IsPrime Suite', Action: MICROFLOW MathTest.TestSuite_IsPrime, ButtonStyle: Primary)
      }
      COLUMN colPrime17 (DesktopWidth: 3) {
        ACTIONBUTTON btnIsPrime17 (Caption: 'Test: 17 is prime', Action: MICROFLOW MathTest.UT_IsPrime_17_ReturnsTrue, ButtonStyle: Default)
      }
      COLUMN colPrime20 (DesktopWidth: 3) {
        ACTIONBUTTON btnIsPrime20 (Caption: 'Test: 20 not prime', Action: MICROFLOW MathTest.UT_IsPrime_20_ReturnsFalse, ButtonStyle: Default)
      }
      COLUMN colPrime2 (DesktopWidth: 3) {
        ACTIONBUTTON btnIsPrime2 (Caption: 'Test: 2 is prime', Action: MICROFLOW MathTest.UT_IsPrime_2_ReturnsTrue, ButtonStyle: Default)
      }
    }
    ROW rowFibHeader {
      COLUMN colFibHeader (DesktopWidth: 12) {
        DYNAMICTEXT sectionFibonacci (Content: 'Fibonacci Tests', RenderMode: H4)
      }
    }
    ROW rowFibTests {
      COLUMN colFibSuite (DesktopWidth: 3) {
        ACTIONBUTTON btnFibSuite (Caption: 'Run Fibonacci Suite', Action: MICROFLOW MathTest.TestSuite_Fibonacci, ButtonStyle: Primary)
      }
      COLUMN colFib0 (DesktopWidth: 3) {
        ACTIONBUTTON btnFib0 (Caption: 'Test: F(0) = 0', Action: MICROFLOW MathTest.UT_Fibonacci_0_Returns0, ButtonStyle: Default)
      }
      COLUMN colFib10 (DesktopWidth: 3) {
        ACTIONBUTTON btnFib10 (Caption: 'Test: F(10) = 55', Action: MICROFLOW MathTest.UT_Fibonacci_10_Returns55, ButtonStyle: Default)
      }
      COLUMN colFib20 (DesktopWidth: 3) {
        ACTIONBUTTON btnFib20 (Caption: 'Test: F(20) = 6765', Action: MICROFLOW MathTest.UT_Fibonacci_20_Returns6765, ButtonStyle: Default)
      }
    }
  }
};
/
